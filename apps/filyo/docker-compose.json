{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "filyo",
      "image": "ghcr.io/mouette03/filyo:latest",
      "isMain": true,
      "internalPort": 3001,
      "environment": [
        { "key": "NODE_ENV", "value": "production" },
        { "key": "JWT_SECRET", "value": "hbY6yIRrxdgjNIFWWxQcn8poUfxOZ6XqlyITolCwwbE" },
        { "key": "LOG_LEVEL", "value": "info" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ],
      "healthCheck": {
        "test": "wget -qO- http://localhost:3001/health",
        "interval": "30s",
        "timeout": "10s",
        "retries": 3,
        "startPeriod": "20s"
      }
    }
  ]
}
