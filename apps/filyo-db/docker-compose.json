{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "filyo",
      "image": "ghcr.io/mouette03/filyo:v1.2.3",
      "internalPort": 3001,
      "environment": [
        { "key": "NODE_ENV", "value": "production" },
        { "key": "JWT_SECRET", "value": "${FILYO_JWT_SECRET}" },
        { "key": "TRUST_PROXY", "value": "${FILYO_TRUST_PROXY}" },
        { "key": "CLEANUP_INTERVAL", "value": "${FILYO_CLEANUP_INTERVAL}" },
        { "key": "TUS_CHUNK_MB", "value": "${FILYO_TUS_CHUNK_MB}" },
        { "key": "REGISTER_DEFAULT_QUOTA", "value": "${FILYO_REGISTER_DEFAULT_QUOTA}" },
        { "key": "LOG_LEVEL", "value": "${FILYO_LOG_LEVEL}" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ],
      "healthCheck": {
        "test": "wget -qO- http://127.0.0.1:3001/health",
        "interval": "30s",
        "timeout": "10s",
        "retries": 3,
        "startPeriod": "20s"
      },
      "isMain": true
    }
  ]
}
