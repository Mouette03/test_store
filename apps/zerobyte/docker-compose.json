{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "zerobyte-init",
      "image": "busybox:1.36",
      "command": ["sh", "-c", "mkdir -p /data && chown -R 1000:1000 /data"],
      "restart": "no",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ]
    },
    {
      "name": "zerobyte",
      "image": "ghcr.io/nicotsx/zerobyte:v0.40",
      "internalPort": 4096,
      "isMain": true,
      "dependsOn": {
        "zerobyte-init": {
          "condition": "service_completed_successfully"
        }
      },
      "environment": [
        {
          "key": "TZ",
          "value": "${TZ}"
        },
        {
          "key": "BASE_URL",
          "value": "${APP_PROTOCOL}://${APP_DOMAIN}"
        },
        {
          "key": "APP_SECRET",
          "value": "${APP_SECRET}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/var/lib/zerobyte"
        },
        {
          "hostPath": "${ZEROBYTE_BACKUP_PATH}",
          "containerPath": "/data",
          "readOnly": true
        }
      ],
      "restart": "unless-stopped"
    }
  ]
}