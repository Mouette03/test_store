{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "netronome-init",
      "image": "privatebin/chown",
      "command": ["101:102", "/data"],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ]
    },
    {
      "name": "netronome",
      "image": "ghcr.io/autobrr/netronome:v0.11.0",
      "internalPort": 7575,
      "isMain": true,
      "dependsOn": {
        "netronome-init": {
          "condition": "service_completed_successfully"
        }
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ]
    }
  ]
}