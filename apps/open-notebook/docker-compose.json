{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "open_notebook",
      "image": "lfnovo/open_notebook:v1-latest-single",
      "isMain": true,
      "internalPort": 8502,
      "addPorts": [
        {
          "containerPort": 5055,
          "hostPort": 5055,
          "tcp": true
        }
      ],
      "environment": [
        {
          "key": "OPEN_NOTEBOOK_ENCRYPTION_KEY",
          "value": "${OPEN_NOTEBOOK_ENCRYPTION_KEY}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/notebook",
          "containerPath": "/app/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/surreal_single",
          "containerPath": "/mydata"
        }
      ],
      "user": "1000:1000",
      "restart": "unless-stopped",
      "healthcheck": {
        "test": ["CMD-SHELL", "wget -qO- http://localhost:8502/health || exit 1"],
        "interval": "30s",
        "timeout": "10s",
        "retries": 5,
        "startPeriod": "30s"
      }
    }
  ]
}
