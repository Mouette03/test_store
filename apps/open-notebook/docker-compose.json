{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "open_notebook",
      "image": "ghcr.io/lfnovo/open-notebook:1.8.1",
      "isMain": true,
      "internalPort": 8502,
      "addPorts": [
        {
          "containerPort": 5055,
          "hostPort": 5055,
          "tcp": true
        }
      ],
      "environment": [
        {
          "key": "OPEN_NOTEBOOK_ENCRYPTION_KEY",
          "value": "${OPEN_NOTEBOOK_ENCRYPTION_KEY}"
        },
        {
          "key": "SURREAL_URL",
          "value": "ws://surrealdb:8000/rpc"
        },
        {
          "key": "SURREAL_USER",
          "value": "root"
        },
        {
          "key": "SURREAL_PASSWORD",
          "value": "root"
        },
        {
          "key": "SURREAL_NAMESPACE",
          "value": "open_notebook"
        },
        {
          "key": "SURREAL_DATABASE",
          "value": "open_notebook"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/notebook",
          "containerPath": "/app/data"
        }
      ],
      "restart": "unless-stopped",
      "dependsOn": ["surrealdb"],
      "healthcheck": {
        "test": ["CMD-SHELL", "curl -f http://localhost:8502/health || exit 1"],
        "interval": "30s",
        "timeout": "10s",
        "retries": 5,
        "startPeriod": "40s"
      }
    },
    {
      "name": "surrealdb",
      "image": "surrealdb/surrealdb:v2",
      "command": "start --log info --user root --pass root rocksdb:/mydata/mydatabase.db",
      "user": "1000:1000",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/surreal",
          "containerPath": "/mydata"
        }
      ],
      "environment": [
        {
          "key": "SURREAL_EXPERIMENTAL_GRAPHQL",
          "value": "true"
        }
      ],
      "restart": "unless-stopped",
      "healthcheck": {
        "test": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": "10s",
        "timeout": "5s",
        "retries": 10,
        "startPeriod": "20s"
      }
    }
  ]
}
